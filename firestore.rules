rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: businesses
    // Document ID: businessId (User UID)
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - slug: string (required)
    //   - plan: string (Gratis, Entrepreneur, Pro)
    //   - isTrial: bool
    //   - trialEndDate: timestamp
    //   - hasUsedTrial: bool
    //   - lastPromoShownAt: timestamp
    //
    // Collection: settings
    // Document ID: promotion
    // Fields:
    //   - isActive: bool
    //   - title: string
    //   - message: string
    //   - imageUrl: string
    //   - frequencyDays: number
    //
    // Collection: super_admins
    // Document ID: userId
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/super_admins/$(request.auth.uid)) || 
         request.auth.token.email == "hector@thebananas.com.mx" ||
         request.auth.uid == "FLOU6hb5bQcBc6Bt0qKPq5u4N7x1");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Rules (Updated: 2026-03-17 20:43 UTC)
    // ===============================================================

    // Settings collection (PRIORITY)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/promotion {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Super Admins collection
    match /super_admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Businesses collection
    match /businesses/{businessId} {
      // Permitir 'get' público para la tarjeta digital y el scanner
      allow get: if true;
      // Solo el dueño o super admin pueden listar o leer todo el documento (incluyendo campos sensibles si los hubiera)
      allow read: if isOwner(businessId) || isSuperAdmin();
      
      // Allow business owner to update specific fields related to promotion and trial
      allow update: if isOwner(businessId) && 
        (
          // Case 1: Updating lastPromoShownAt
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastPromoShownAt'])) ||
          // Case 2: Activating trial
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['plan', 'isTrial', 'trialEndDate', 'hasUsedTrial', 'lastPromoShownAt']) &&
            request.resource.data.plan == 'Entrepreneur' &&
            request.resource.data.isTrial == true &&
            request.resource.data.hasUsedTrial == true &&
            resource.data.hasUsedTrial != true // Prevent re-using trial
          )
        );
      
      allow write: if isSuperAdmin();
      
      // Subcollections
      match /config/{configId} {
        allow read: if true; // Publicly readable for the digital card
        allow write: if isOwner(businessId) || isSuperAdmin();
      }

      match /customers/{customerId} {
        allow read, create: if true; // Public for digital card registration
        allow update: if true; // Public for scanner (PIN validation)
        allow delete: if isOwner(businessId) || isSuperAdmin();

        match /transactions/{transactionId} {
          allow read: if true;
          allow write: if true;
        }
      }

      match /surveyResponses/{responseId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // Slugs collection
    match /businessSlugs/{slug} {
      allow read: if true; // Publicly readable for routing
      allow write: if isAuthenticated() || isSuperAdmin();
    }

    // Blog posts
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Zapier triggers
    match /new_business_registrations/{id} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isSuperAdmin();
    }
  }
}
